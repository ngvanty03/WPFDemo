<Window x:Class="ProductManagement.UI.Views.ProductDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagement.UI.Views"
        mc:Ignorable="d"
        Closing="Window_Closing" WindowStartupLocation="CenterOwner"        
        ResizeMode="NoResize"
        Title="Product Detail" Height="350" Width="550"
        FocusManager.FocusedElement="{Binding ElementName=txtSKU}">
    <Grid  Margin="0,50,0,0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="150"></ColumnDefinition>           
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock  Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" 
                   Margin="0,0,0,0" 
                   TextWrapping="NoWrap" 
                   Text="Category:" VerticalAlignment="Center"/>
        <ComboBox TabIndex="2" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Stretch" 
                  Margin="10,0,0,0" VerticalAlignment="Center" Height="20" />
        <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" 
            Margin="0,0,0,0" 
            TextWrapping="NoWrap" 
            Text="SKU:" VerticalAlignment="Center"/>
        <TextBox Name="txtSKU" TabIndex="1" Grid.Row="0"  Grid.Column="1"  Margin="10,0,0,0" HorizontalAlignment="Stretch" Height="20" ></TextBox>
        
        <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" 
     Margin="0,0,0,0" 
     TextWrapping="NoWrap" 
     Text="Name:" VerticalAlignment="Center"/>
        <TextBox TabIndex="3" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"  Margin="10,0,0,0" HorizontalAlignment="Stretch" Height="20" ></TextBox>
        <TextBlock Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right" 
Margin="0,0,0,0" 
TextWrapping="NoWrap" 
Text="Description:" VerticalAlignment="Center"/>
        <TextBox TabIndex="4" Grid.Row="2" Grid.Column="1" 
                 Grid.ColumnSpan="3"  Margin="10,0,0,0" HorizontalAlignment="Stretch" Height="70" ></TextBox>
        <CheckBox TabIndex="5" Grid.Row="3" Grid.Column="1" Content="Is Active"
          HorizontalAlignment="Left" Margin="10,0,0,0" 
          VerticalAlignment="Center"/>
        <StackPanel Grid.Row="4" Grid.Column="1"  Orientation="Horizontal"
                 Grid.ColumnSpan="3">
            <Button TabIndex="6" Height="30" Width="70" Content="Save" Margin="10,0,0,0"></Button>
            <Button TabIndex="7" Height="30" Width="70" Content="Cancel" Margin="15,0,0,0"></Button>
        </StackPanel>
    </Grid>
</Window>
