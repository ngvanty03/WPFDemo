<Window x:Class="ProductManagement.UI.Views.ProductDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagement.UI.Views"
        mc:Ignorable="d"
        Closing="Window_Closing" WindowStartupLocation="CenterOwner"        
        ResizeMode="NoResize"
        Title="Product Detail" Height="400" Width="550"
        FocusManager.FocusedElement="{Binding ElementName=txtSKU}">
    <Grid  Margin="0,30,0,0" >
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="IsEnabled" Value="True"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="150"></ColumnDefinition>           
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>            
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock  Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" 
                   Margin="0,0,0,0" 
                   TextWrapping="NoWrap" 
                   Text="SKU:" VerticalAlignment="Center"/>
        <TextBox Name="txtSKU" TabIndex="1" Grid.Row="0"  Grid.Column="1" 
         Text="{Binding Product.SKU, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
         Margin="10,0,0,0" HorizontalAlignment="Stretch"></TextBox>
        <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" 
            Margin="0,0,0,0" 
            TextWrapping="NoWrap" 
            Text="Category:" VerticalAlignment="Center"/>
        <ComboBox TabIndex="2" Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Categories}" 
                  SelectedValue="{Binding Product.CategoryId, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                    SelectedValuePath="Id"
                    DisplayMemberPath="Name"
                     HorizontalAlignment="Stretch"
                  Margin="10,0,0,0" />      
        
        <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" 
     Margin="0,0,0,0" 
     TextWrapping="NoWrap" 
     Text="Name:" VerticalAlignment="Center"/>
        <TextBox TabIndex="3" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"  
                 Text="{Binding Product.Name, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                 Margin="10,0,0,0" HorizontalAlignment="Stretch" ></TextBox>
        <TextBlock Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right" 
Margin="0,0,0,0" 
TextWrapping="NoWrap" 
Text="Description:" VerticalAlignment="Center"/>
        <TextBox TabIndex="4" Grid.Row="2" Grid.Column="1" 
                 Text="{Binding Product.Description, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                 Grid.ColumnSpan="3"  Margin="10,0,0,0" VerticalContentAlignment="Top" HorizontalAlignment="Stretch" Height="70" ></TextBox>
        <CheckBox TabIndex="5" Grid.Row="3" Grid.Column="1" Content="Is Active"
                  IsChecked="{Binding Product.IsActive, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
          HorizontalAlignment="Left" Margin="10,0,0,0" 
          VerticalAlignment="Center"/>
        <StackPanel Grid.Row="4" Grid.Column="1"  Orientation="Horizontal"
                 Grid.ColumnSpan="3">
            <Button IsDefault="True" Command="{Binding SaveCommand}" TabIndex="6"  Width="70" Content="Save" Margin="10,0,0,0"></Button>
            <Button IsCancel="True" Command="{Binding CloseCommand}" TabIndex="7" Width="70" Content="Cancel" Margin="15,0,0,0"></Button>
        </StackPanel>
        <TextBlock Margin="10,10,0,0" Grid.Row="5" Grid.Column="1" TextWrapping="WrapWithOverflow" Foreground="Red" FontSize="18" FontWeight="SemiBold"
                 Grid.ColumnSpan="4" Text="{Binding ErrorMessage}"></TextBlock>
        <TextBlock Margin="10,10,0,0" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4" 
                   HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LoadingTextBlockStyle}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</Window>
