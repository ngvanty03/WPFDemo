{
  "ConnectionStrings": {
    "DefaultConnection": "Server=LAPTOP-C17G79QD\\SQLEXPRESS;Database=UACDemo;User ID=sqlAdmin;Password=123456;TrustServerCertificate=True;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Async", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/asyncLog-.txt",
                "rollingInterval": "Day",
                "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] [ThreadId: {ThreadId}] {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId" ]
  }
}
